# Supabase (obbligatorio per dati reali)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe (per pagamenti crediti) — chiavi pubbliche, esposte al client
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key_here
VITE_STRIPE_PRICE_10=price_10_credits
VITE_STRIPE_PRICE_30=price_30_credits
VITE_STRIPE_PRICE_70=price_70_credits
VITE_STRIPE_PRICE_150=price_150_credits

# ---------------------------------------------------------------------------
# Edge Functions (lato server, NON esposte al client)
# Imposta queste nel dashboard Supabase: Project Settings > Edge Functions > Secrets
# ---------------------------------------------------------------------------

# Chiave segreta Stripe per creare checkout session (server only)
STRIPE_SECRET_KEY=sk_live_or_test_key_here

# Segreto per verificare la firma dei webhook Stripe (server only)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Chiave service role di Supabase per scritture DB bypassando RLS (server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---- Senza queste chiavi il sito funziona in modalita DEMO ----
# ---- I demo usano dati fittizi e WhatsApp con numeri di esempio ----
